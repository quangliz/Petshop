@startuml
left to right direction

actor "Khách hàng" as User
actor "Nhân viên hỗ trợ" as Support
actor "PGVector /\nOpenAI" as AI

rectangle "Hồ sơ thú cưng và Catbot" {
  usecase "Tạo / sửa\nhồ sơ thú cưng" as PetCrud
  usecase "Khai báo\nsức khỏe và dị ứng" as Allergy
  usecase "Chọn pet làm\nngữ cảnh" as ChoosePet
  usecase "Gửi câu hỏi\nCatbot" as Ask
  usecase "Tìm sản phẩm\ncó thật" as ProductSearch
  usecase "Tìm knowledge /\nforum" as KnowledgeSearch
  usecase "Stream câu trả lời\nvà thẻ sản phẩm" as Answer
  usecase "Guardrail /\ncảnh báo an toàn" as Safety
  usecase "Chuyển giao\nngười thật" as Handoff
}

User --> PetCrud
User --> ChoosePet
User --> Ask
Support --> Handoff
AI --> ProductSearch
AI --> KnowledgeSearch

PetCrud ..> Allergy : <<include>>
ChoosePet ..> Ask : <<include>>
Ask ..> ProductSearch : <<include>>
Ask ..> KnowledgeSearch : <<include>>
Ask ..> Safety : <<include>>
ProductSearch ..> Answer
KnowledgeSearch ..> Answer
Safety ..> Handoff : <<extend>>
@enduml
