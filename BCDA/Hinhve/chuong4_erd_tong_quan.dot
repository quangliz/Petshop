digraph G {
  graph [rankdir=LR, splines=ortho, bgcolor="white", fontname="DejaVu Sans", nodesep=0.5, ranksep=0.75];
  node [shape=record, style="rounded,filled", fillcolor="#F8FAFC", color="#334155", fontname="DejaVu Sans", fontsize=10];
  edge [color="#64748B", arrowsize=0.7];

  users [label="{users|refresh_sessions|pets|wishlist_items}"];
  catalog [label="{catalog|categories|products|product_variants|product_images|banners}"];
  commerce [label="{commerce|carts|cart_items|orders|order_items|payments|inventory_reservations|promotions|order_returns|order_return_items}"];
  forum [label="{forum|forum_threads|forum_replies|forum_thread_votes|forum_reply_votes}"];
  ai [label="{AI/knowledge|knowledge_docs|chat_sessions|chat_messages|ai_call_logs|audit_logs}"];

  users -> commerce [label="user_id"];
  users -> forum [label="author/vote"];
  users -> ai [label="chat, owner, audit"];
  users -> catalog [label="wishlist"];
  catalog -> commerce [label="product_id / variant_id"];
  catalog -> ai [label="product embeddings"];
  forum -> ai [label="eligible knowledge"];
  commerce -> ai [label="support context"];
}
