@startuml

title Quy trình nghiệp vụ mua hàng và thanh toán

start
:Xem / tìm kiếm sản phẩm;
:Xem chi tiết và chọn biến thể;
:Thêm / cập nhật giỏ hàng;
:Nhập thông tin nhận hàng\nvà phương thức thanh toán;
:Backend validate dữ liệu\nvà idempotency key;
:Khóa dòng tồn kho\nSELECT FOR UPDATE;

if (Đủ tồn kho?) then (Có)
  :Tạo order, order items\nvà reservation cho SePay;
  if (Phương thức thanh toán?) then (COD)
    :COD: đơn chờ xử lý;
    stop
  else (SePay VietQR)
    :Tạo QR thanh toán\nhết hạn 15 phút;
    if (Quá hạn thanh toán?) then (Có)
      :Giải phóng reservation;
      stop
    else (Không)
      :Nhận webhook SePay;
      if (Xác minh hợp lệ?) then (Có)
        :Commit reservation\nvà cập nhật đã thanh toán;
        stop
      else (Không)
        :Từ chối cập nhật và ghi log;
        stop
      endif
    endif
  endif
else (Không)
  :Trả lỗi và yêu cầu\nđiều chỉnh giỏ hàng;
  stop
endif
@enduml
