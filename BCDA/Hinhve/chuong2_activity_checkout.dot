digraph G {
  graph [rankdir=TB, splines=ortho, bgcolor="white", fontname="DejaVu Sans", nodesep=0.45, ranksep=0.5];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#334155", fontname="DejaVu Sans", fontsize=11, margin="0.10,0.07"];
  edge [color="#475569", arrowsize=0.8, fontname="DejaVu Sans", fontsize=10];

  start [label="Xem / tìm kiếm sản phẩm"];
  detail [label="Chọn biến thể và số lượng"];
  cart [label="Thêm / cập nhật giỏ hàng"];
  checkout [label="Nhập thông tin nhận hàng\nvà phương thức thanh toán"];
  idem [label="Validate request\nvà Idempotency-Key"];
  lock [label="Khóa dòng tồn kho\nSELECT FOR UPDATE"];
  enough [shape=diamond, label="Đủ tồn kho?"];
  create [label="Tạo order + order_items\nsnapshot giá"];
  method [shape=diamond, label="Phương thức?"];
  cod [label="COD: đơn chờ xử lý"];
  sepay [label="SePay: tạo QR 15 phút\nvà reservation có grace"];
  paid [shape=diamond, label="Webhook hợp lệ?"];
  commit [label="Commit reservation\nvà cập nhật đã thanh toán"];
  release [label="Worker giải phóng\nreservation quá hạn"];
  fail [label="Trả lỗi để khách\nđiều chỉnh giỏ hàng"];

  start -> detail -> cart -> checkout -> idem -> lock -> enough;
  enough -> fail [label="Không"];
  enough -> create [label="Có"];
  create -> method;
  method -> cod [label="COD"];
  method -> sepay [label="SePay"];
  sepay -> paid;
  paid -> commit [label="Có"];
  paid -> release [label="Không / quá hạn"];
}
