@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #334155
}

actor "Khách hàng" as User
actor "Chuyên gia thú y" as Expert
actor "Quản trị viên" as Admin
actor "Kho RAG" as Rag

rectangle "Diễn đàn chuyên gia" {
  usecase "Xem / lọc\nthread" as List
  usecase "Tạo chủ đề\nthảo luận" as Create
  usecase "Trả lời /\nbình luận" as Reply
  usecase "Upvote /\ndownvote" as Vote
  usecase "Chọn câu trả lời\ntốt nhất" as Accepted
  usecase "Câu trả lời\nchuyên gia" as ExpertAnswer
  usecase "Kiểm duyệt\nnội dung" as Moderate
  usecase "Đồng bộ tri thức\nvào RAG" as Sync
}

User --> List
User --> Create
User --> Reply
User --> Vote
User --> Accepted

Expert --> Reply
Expert --> ExpertAnswer

Admin --> Moderate
Admin --> Sync
Rag --> Sync

Reply ..> Vote : <<extend>>
ExpertAnswer ..> Sync : điểm chất lượng
Accepted ..> Sync : điểm chất lượng
Moderate ..> Sync
@enduml
