digraph G {
  graph [rankdir=TB, splines=ortho, bgcolor="white", fontname="DejaVu Sans", nodesep=0.45, ranksep=0.55];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#334155", fontname="DejaVu Sans", fontsize=11, margin="0.10,0.07"];
  edge [color="#475569", fontname="DejaVu Sans", fontsize=10, arrowsize=0.8];

  start [label="Người dùng checkout\nIdempotency-Key"];
  lock [label="pg_advisory_xact_lock\ncho scope + key"];
  stock [label="SELECT ... FOR UPDATE\nproducts / variants"];
  validate [label="Validate sản phẩm,\nbiến thể, coupon, tồn kho"];
  order [label="Tạo order + order_items\nsnapshot giá"];
  reserve [label="Trừ tồn kho và tạo\ninventory_reservations"];
  qr [label="Tạo Payment SePay\nmerchant_ref = order_code\nQR hết hạn 15 phút"];
  webhook [label="SePay webhook\nAuthorization: Apikey"];
  verify [label="Kiểm tra giao dịch\nhướng tiền, mã đơn,\nsố tiền, duplicate"];
  commit [label="Commit reservation\ncập nhật paid, sold_count"];
  release [label="Worker quét reservation\nquá hạn 15 + 5 phút\ngiải phóng tồn kho"];
  review [label="requires_review\nnếu cần đối soát tồn kho"];

  start -> lock -> stock -> validate -> order -> reserve -> qr;
  qr -> webhook [label="người dùng chuyển khoản"];
  webhook -> verify -> commit;
  verify -> review [label="không reacquire được"];
  reserve -> release [label="không thanh toán"];
}
