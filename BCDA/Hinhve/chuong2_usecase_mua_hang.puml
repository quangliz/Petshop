@startuml
left to right direction
skinparam linetype polyline
actor "Khách vãng lai" as Guest
actor "Khách hàng" as User

usecase "Xem danh mục /\ntìm kiếm" as Search
usecase "Lọc và\nsắp xếp" as Filter
usecase "Xem chi tiết\nsản phẩm" as Detail
usecase "Chọn biến thể\nSKU" as Variant
usecase "Quản lý\ngiỏ hàng" as Cart
usecase "Áp dụng\nkhuyến mãi" as Coupon
usecase "Checkout /\ngiữ kho" as Checkout
usecase "Thanh toán\nCOD / SePay VietQR" as Payment
usecase "Theo dõi đơn /\ntra cứu guest" as Tracking
usecase "Yêu cầu\nđổi trả" as Return
usecase "Đánh giá\nđã mua" as Review

Guest --> Search
Guest --> Detail
Guest --> Cart
Guest --> Checkout
Guest --> Tracking

User --> Search
User --> Detail
User --> Cart
User --> Checkout
User --> Tracking
User --> Return
User --> Review

Search ..> Filter : <<include>>
Detail ..> Variant : <<include>>
Cart ..> Coupon : <<extend>>
Checkout ..> Payment : <<include>>
@enduml
