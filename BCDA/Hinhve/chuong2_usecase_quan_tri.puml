@startuml
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #F8FAFC
  BorderColor #334155
}

actor "Catalog\nmanager" as CatalogManager
actor "Order\noperator" as OrderOperator
actor "Content\nmanager" as ContentManager
actor "Admin" as Admin

rectangle "Admin dashboard" {
  usecase "Quản lý sản phẩm /\ndanh mục" as Catalog
  usecase "Quản lý biến thể /\nSKU / ảnh" as Variant
  usecase "Quản lý\nđơn hàng" as Orders
  usecase "Xử lý\nđổi trả" as Returns
  usecase "Quản lý\nkhuyến mãi" as Promotions
  usecase "Kiểm duyệt\nforum" as Forum
  usecase "Quản lý\nknowledge" as Knowledge
  usecase "Reindex\nembedding" as Reindex
  usecase "Quản lý người dùng\nvà role" as Users
  usecase "Thống kê /\naudit log" as Observe
}

CatalogManager --> Catalog
CatalogManager --> Variant
CatalogManager --> Promotions

OrderOperator --> Orders
OrderOperator --> Returns

ContentManager --> Forum
ContentManager --> Knowledge
ContentManager --> Reindex

Admin --> Catalog
Admin --> Orders
Admin --> Users
Admin --> Observe
Admin --> Reindex

Catalog ..> Variant : <<include>>
Knowledge ..> Reindex : <<extend>>
Forum ..> Knowledge : nội dung chất lượng
@enduml
