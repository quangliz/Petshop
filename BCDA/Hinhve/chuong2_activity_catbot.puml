@startuml

title Quy trình nghiệp vụ tư vấn bằng Catbot

start
:Người dùng mở widget Catbot;
:Chọn hồ sơ thú cưng\nhoặc ngữ cảnh sản phẩm;
:Gửi câu hỏi qua API streaming;
:Backend lưu message\nvà nạp history;
:LangGraph agent phân tích yêu cầu;

if (Cần gọi tool?) then (Sản phẩm)
  :Tìm sản phẩm trong catalog;
elseif (Kiến thức)
  :Tìm knowledge / forum\ntrong PGVector;
elseif (Hồ sơ)
  :Đọc pet profile của user;
else (Không)
endif

if (Có rủi ro hoặc cần người thật?) then (Có)
  :Chuyển phiên sang\npending_human;
  :Lưu trạng thái phiên\nvà log AI;
  stop
else (Không)
  :LLM sinh câu trả lời\nbám theo dữ liệu;
  :Stream SSE về frontend\nvà render product card;
  :Lưu assistant message\nvà log AI;
  stop
