@startuml
left to right direction

actor "Người dùng" as User
actor "Quản lý" as Manager
actor "Quản trị" as Admin

rectangle "Hệ thống ThePawsome" {
  package "Người dùng" {
    usecase "Quản lý tài khoản\nvà hồ sơ thú cưng" as U1
    usecase "Mua sắm và\nthanh toán" as U2
    usecase "Tham gia diễn đàn" as U3
    usecase "Tư vấn bằng Catbot" as U4
  }

  together {
    package "Quản lý" {
      usecase "Quản lý catalog" as M1
      usecase "Quản lý đơn hàng\nvà đổi trả" as M2
      usecase "Quản lý nội dung\nvà tri thức" as M3
      usecase "Tiếp nhận hỗ trợ" as M4
    }

    package "Quản trị" {
      usecase "Quản lý người dùng\nvà phân quyền" as A1
      usecase "Theo dõi thống kê\nvà kiểm toán" as A2
      usecase "Cấu hình hệ thống" as A3
    }
  }
}

User -[hidden]right- U1
U1 -[hidden]right- M1
M1 -[hidden]right- Manager
M4 -[hidden]down- A1
Manager -[hidden]down- Admin

User --> U1
User --> U2
User --> U3
User --> U4

M1 <-- Manager
M2 <-- Manager
M3 <-- Manager
M4 <-- Manager

A1 <-- Admin
A2 <-- Admin
A3 <-- Admin
M1 <-- Admin
M2 <-- Admin
M3 <-- Admin
@enduml
