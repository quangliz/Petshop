digraph G {
  graph [rankdir=LR, compound=true, splines=ortho, bgcolor="white", fontname="DejaVu Sans", nodesep=0.55, ranksep=0.8];
  node [shape=box, style="rounded,filled", fillcolor="#F8FAFC", color="#334155", fontname="DejaVu Sans", fontsize=11, margin="0.10,0.07"];
  edge [color="#475569", fontname="DejaVu Sans", fontsize=10, arrowsize=0.8];

  subgraph cluster_frontend {
    label="Frontend - Next.js App Router";
    color="#CBD5E1";
    style="rounded";
    pages [label="Route groups\n(shop/auth/admin)"];
    components [label="Components\nUI, Chat, Forum, Review"];
    query [label="TanStack Query\nAxios client"];
    state [label="Zustand\nAuth + viewing product"];
  }

  subgraph cluster_backend {
    label="Backend - FastAPI";
    color="#CBD5E1";
    style="rounded";
    routers [label="API routers\nauth, products, orders,\npayments, forum, chat, admin"];
    deps [label="Dependencies\nAsyncSession, JWT, RBAC"];
    services [label="Services\nretrieval, indexing,\ninventory, payments, safety"];
    models [label="SQLAlchemy models\n28 business tables"];
  }

  subgraph cluster_data {
    label="Data & runtime";
    color="#CBD5E1";
    style="rounded";
    postgres [label="PostgreSQL + pgvector"];
    redis [label="Redis\ncache/rate limit"];
    worker [label="reservation-worker\nexpire held stock"];
  }

  subgraph cluster_external {
    label="External services";
    color="#CBD5E1";
    style="rounded";
    openai [label="OpenAI\nchat + embeddings"];
    cohere [label="Cohere rerank\noptional"];
    cloudinary [label="Cloudinary\nimage storage"];
    sepay [label="SePay / VietQR\nQR + webhook"];
    google [label="Google OAuth"];
  }

  pages -> components;
  components -> query;
  components -> state;
  query -> routers [label="REST/SSE"];
  routers -> deps;
  routers -> services;
  routers -> models;
  services -> models;
  models -> postgres;
  services -> redis;
  worker -> postgres;
  services -> openai;
  services -> cohere;
  services -> cloudinary;
  services -> sepay;
  routers -> google;
}
