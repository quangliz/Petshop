# ── Database ──────────────────────────────
# Dev local qua docker-compose. Khi deploy dùng URL thật từ Railway/Render.
DATABASE_URL=postgresql+asyncpg://petshop:change_this_strong_password@localhost:5432/petshop_db

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────
# Sinh bằng: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_RANDOM_48_BYTE_URL_SAFE_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Cloudinary (tuần 2 — upload ảnh) ─────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OpenAI (tuần 4 — chatbot) ────────────
# LẤY KEY TẠI: https://platform.openai.com/api-keys
# ĐẶT HARD BUDGET ($10/tháng) trên dashboard để tránh phát sinh cost bất ngờ
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── VNPay sandbox (tuần 3 — thanh toán) ──
# Đăng ký sandbox tại https://sandbox.vnpayment.vn/devreg/
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/orders/payment/callback
