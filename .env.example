# ── Database ──────────────────────────────
# Local dev default. The backend also accepts postgresql+asyncpg:// URLs.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production-local
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
GUEST_ORDER_TOKEN_EXPIRE_HOURS=24
COOKIE_SECURE=false

# ── Google OAuth ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Gmail SMTP) ────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# ── App ───────────────────────────────────
ENVIRONMENT=development
AUTO_CREATE_TABLES=false
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Cloudinary ────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI / RAG ──────────────────────────
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
AI_EVAL_JUDGE_MODEL=gpt-4o
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_EVAL_TOKEN_BUDGET=200000

# ── LangSmith tracing (optional) ──────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=petshop-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Cohere Rerank (optional) ──────────────
COHERE_API_KEY=

# ── SePay Configurations ──────────────────
SEPAY_API_KEY=your_sepay_api_key_or_token
SEPAY_WEBHOOK_SECRET_KEY=
SEPAY_ACCOUNT_NUMBER=123456789
SEPAY_ACCOUNT_NAME=PETSHOP THEPAWSOME
SEPAY_BANK=MBBank
SEPAY_RETURN_URL=http://localhost:3000/orders/payment/callback
SEPAY_PAYMENT_TTL_MINUTES=15
INVENTORY_RESERVATION_GRACE_MINUTES=5
RESERVATION_SWEEP_INTERVAL_SECONDS=60
PET_AVATAR_MAX_BYTES=5242880

# ── Docker / CI ───────────────────────────
DOCKER_HUB_USERNAME=
IMAGE_TAG=latest

# ── Frontend (NEXT_PUBLIC_* are baked at build time) ──
# Set in frontend/.env.local for local dev
# Set as GitHub secrets + Docker build-args for CI
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
