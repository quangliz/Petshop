# ── Database ──────────────────────────────
# DATABASE_URL=postgresql+asyncpg://petshop_user:petshop_password@localhost:5432/petshop
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=postgres

# ── Redis ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

# ── Google OAuth ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Gmail SMTP) ────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# ── App ───────────────────────────────────
ENVIRONMENT=development
AUTO_CREATE_TABLES=false
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Cloudinary ────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI (tuần 4) ───────────────────────
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── LangSmith tracing (optional) ──────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=petshop-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── VNPay (tuần 3) ────────────────────────
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/orders/payment/callback

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Docker / CI ───────────────────────────
DOCKER_HUB_USERNAME=
IMAGE_TAG=latest

# ── Frontend (NEXT_PUBLIC_* are baked at build time) ──
# Set in frontend/.env.local for local dev
# Set as GitHub secrets + Docker build-args for CI
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
